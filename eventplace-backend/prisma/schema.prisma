generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  email     String   @unique
  password  String
  birthDate DateTime
  avatar    String?
  rating    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cep       String

  events  Event[]
  tickets Ticket[]

}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  startAt     DateTime
  endAt       DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cep     String
  userId  String
  user    User     @relation(fields: [userId], references: [id])
  tickets Ticket[]
}

model Ticket {
  id        String   @id @default(uuid())
  price     Float
  quantity  Int
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}